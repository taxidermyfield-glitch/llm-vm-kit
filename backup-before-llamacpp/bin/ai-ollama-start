#!/usr/bin/env bash
set -Eeuo pipefail

AI_STACK_DIR="${AI_STACK_DIR:-$(cat /etc/ai-stack/stack-dir 2>/dev/null || echo /opt/llm-vm-kit)}"
# shellcheck disable=SC1091
source "$AI_STACK_DIR/lib/env.sh"

mkdir -p "$OLLAMA_MODELS" "$AI_HOME/logs" "$HOME/.ollama"

if curl -fsS "$(ai_ollama_url)/api/tags" >/dev/null 2>&1; then
  exit 0
fi

export OLLAMA_HOST
export OLLAMA_MODELS
export OLLAMA_CONTEXT_LENGTH="$AI_CONTEXT_LENGTH"
export OLLAMA_FLASH_ATTENTION="${OLLAMA_FLASH_ATTENTION:-1}"

nohup env \
  OLLAMA_HOST="$OLLAMA_HOST" \
  OLLAMA_MODELS="$OLLAMA_MODELS" \
  OLLAMA_CONTEXT_LENGTH="$AI_CONTEXT_LENGTH" \
  OLLAMA_FLASH_ATTENTION="$OLLAMA_FLASH_ATTENTION" \
  ollama serve > "$AI_HOME/logs/ollama.log" 2>&1 &

for _ in $(seq 1 45); do
  if curl -fsS "$(ai_ollama_url)/api/tags" >/dev/null 2>&1; then
    echo "Ollama running at $(ai_ollama_url)"
    exit 0
  fi
  sleep 1
done

echo "Ollama did not become ready. See: $AI_HOME/logs/ollama.log" >&2
exit 1
