#!/usr/bin/env bash
set -Eeuo pipefail

QUIET="${1:-}"

AI_STACK_DIR="${AI_STACK_DIR:-$(cat /etc/ai-stack/stack-dir 2>/dev/null || echo /opt/llm-vm-kit)}"
# shellcheck disable=SC1091
source "$AI_STACK_DIR/lib/env.sh"

port="${AI_BROWSER_CDP_PORT:-9222}"
url="http://127.0.0.1:${port}"

set_env_value() {
  local file="$1" key="$2" value="$3"
  python3 - "$file" "$key" "$value" <<'PY'
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]
line = f'{key}="{value}"'

lines = path.read_text().splitlines() if path.exists() else []
out = []
found = False

for existing in lines:
    if existing.startswith(f"{key}="):
        out.append(line)
        found = True
    else:
        out.append(existing)

if not found:
    out.append(line)

path.write_text("\n".join(out) + "\n")
PY
}

append_env_value() {
  local file="$1" key="$2" value="$3"
  mkdir -p "$(dirname "$file")"
  touch "$file"

  if grep -q "^${key}=" "$file"; then
    sed -i "s|^${key}=.*|${key}=\"${value}\"|" "$file"
  else
    echo "${key}=\"${value}\"" >> "$file"
  fi
}

is_usable_browser() {
  local bin="$1"
  [[ -x "$bin" ]] || return 1

  local version_output
  version_output="$("$bin" --version 2>&1 || true)"

  [[ -n "$version_output" ]] || return 1

  if echo "$version_output" | grep -qiE 'snap|requires the chromium snap|command .* requires'; then
    return 1
  fi

  return 0
}

find_browser() {
  local candidates=(
    "/usr/bin/google-chrome"
    "/usr/bin/google-chrome-stable"
    "/opt/google/chrome/google-chrome"
    "/usr/bin/chromium"
    "/usr/bin/chromium-browser"
  )

  local c
  for c in "${candidates[@]}"; do
    if is_usable_browser "$c"; then
      echo "$c"
      return 0
    fi
  done

  local name
  for name in google-chrome google-chrome-stable chromium chromium-browser brave-browser; do
    if command -v "$name" >/dev/null 2>&1; then
      c="$(command -v "$name")"
      if is_usable_browser "$c"; then
        echo "$c"
        return 0
      fi
    fi
  done

  return 1
}

mkdir -p "$AI_HOME/browser-profile" "$AI_HOME/logs" "$AI_HERMES_HOME"

if curl -fsS "$url/json/version" >/dev/null 2>&1; then
  set_env_value "$AI_ENV_FILE" "AI_BROWSER_CDP_URL" "$url"
  append_env_value "$AI_HERMES_HOME/.env" "BROWSER_CDP_URL" "$url"
  [[ "$QUIET" == "--quiet" ]] || echo "Browser CDP already running at $url"
  exit 0
fi

browser_bin="$(find_browser || true)"

if [[ -z "$browser_bin" ]]; then
  echo "No usable Chrome/Chromium browser found." >&2
  echo "Install Google Chrome with:" >&2
  echo "  cd /tmp" >&2
  echo "  curl -fsSL -o google-chrome.deb https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb" >&2
  echo "  sudo apt-get install -y ./google-chrome.deb" >&2
  exit 1
fi

# Clean up stale sessions using this automation profile/port.
pkill -f "remote-debugging-port=${port}" 2>/dev/null || true
pkill -f "${AI_HOME}/browser-profile" 2>/dev/null || true
sleep 1

rm -rf "$AI_HOME/browser-profile"
mkdir -p "$AI_HOME/browser-profile" "$AI_HOME/logs"

args=(
  "--headless=new"
  "--remote-debugging-address=127.0.0.1"
  "--remote-debugging-port=${port}"
  "--remote-allow-origins=*"
  "--user-data-dir=${AI_HOME}/browser-profile"
  "--disable-dev-shm-usage"
  "--disable-gpu"
  "--disable-software-rasterizer"
  "--no-first-run"
  "--no-default-browser-check"
  "--disable-background-networking"
  "--disable-sync"
  "--disable-extensions"
  "--disable-features=Translate,OptimizationHints,MediaRouter"
  "--enable-features=NetworkService,NetworkServiceInProcess"
  "--window-size=1440,1000"
  "--hide-scrollbars"
  "about:blank"
)

if [[ "$(id -u)" -eq 0 ]]; then
  args+=("--no-sandbox")
fi

nohup "$browser_bin" "${args[@]}" > "$AI_HOME/logs/browser.log" 2>&1 &

for _ in $(seq 1 45); do
  if curl -fsS "$url/json/version" >/dev/null 2>&1; then
    set_env_value "$AI_ENV_FILE" "AI_BROWSER_CDP_URL" "$url"
    append_env_value "$AI_HERMES_HOME/.env" "BROWSER_CDP_URL" "$url"
    [[ "$QUIET" == "--quiet" ]] || echo "Browser CDP running at $url using $browser_bin"
    exit 0
  fi
  sleep 1
done

echo "Browser did not become ready. See: $AI_HOME/logs/browser.log" >&2
echo "Browser binary used: $browser_bin" >&2
exit 1
