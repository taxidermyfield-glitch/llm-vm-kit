#!/usr/bin/env bash
set -Eeuo pipefail

QUIET="${1:-}"

AI_STACK_DIR="${AI_STACK_DIR:-$(cat /etc/ai-stack/stack-dir 2>/dev/null || echo /opt/llm-vm-kit)}"
# shellcheck disable=SC1091
source "$AI_STACK_DIR/lib/env.sh"

mkdir -p "$AI_OPENCODE_HOME" "$AI_HERMES_HOME" "$AI_PROJECTS"

cat > "$AI_OPENCODE_HOME/opencode.json" <<EOF_JSON
{
  "\$schema": "https://opencode.ai/config.json",
  "model": "ollama/${AI_MODEL}",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Local",
      "options": {
        "baseURL": "$(ai_ollama_openai_url)",
        "apiKey": "ollama"
      },
      "models": {
        "${AI_MODEL}": {
          "name": "${AI_MODEL}",
          "limit": {
            "context": ${AI_CONTEXT_LENGTH},
            "output": 8192
          }
        }
      }
    }
  },
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "webfetch": "ask"
  }
}
EOF_JSON

cat > "$AI_HERMES_HOME/config.yaml" <<EOF_YAML
model:
  default: "${AI_MODEL}"
  provider: custom
  base_url: "$(ai_ollama_openai_url)"
  api_key: "ollama"
  context_length: ${AI_CONTEXT_LENGTH}

terminal:
  backend: local
  cwd: "${AI_PROJECTS}"
  timeout: ${AI_TERMINAL_TIMEOUT}

approvals:
  mode: ${AI_APPROVAL_MODE}
  timeout: 60
  cron_mode: deny
  mcp_reload_confirm: true
  destructive_slash_confirm: true

memory:
  memory_enabled: true
  user_profile_enabled: true

agent:
  max_turns: 90

delegation:
  model: "${AI_MODEL}"
  provider: custom
  base_url: "$(ai_ollama_openai_url)"
  api_key: "ollama"
  max_iterations: 30

toolsets:
  - hermes-cli

web:
  search_backend: "${AI_WEB_SEARCH_BACKEND}"
EOF_YAML

if [[ -n "$AI_WEB_EXTRACT_BACKEND" ]]; then
  cat >> "$AI_HERMES_HOME/config.yaml" <<EOF_YAML
  extract_backend: "${AI_WEB_EXTRACT_BACKEND}"
EOF_YAML
fi

if [[ -n "$AI_BROWSER_CDP_URL" ]]; then
  cat >> "$AI_HERMES_HOME/config.yaml" <<EOF_YAML

browser:
  cdp_url: "${AI_BROWSER_CDP_URL}"
EOF_YAML
fi

if [[ ! -f "$AI_HERMES_HOME/SOUL.md" ]]; then
  cat > "$AI_HERMES_HOME/SOUL.md" <<'EOF_SOUL'
You are an autonomous research and engineering worker running on a rented GPU VM.

Default behavior:
- Work inside /workspace/projects unless instructed otherwise.
- Use web/search/browser tools for current external facts.
- Use terminal and code execution carefully.
- Prefer reversible steps and keep an audit trail.
- Ask before destructive filesystem operations, credential handling, purchases, account actions, or irreversible external side effects.
- When building tools or MCP servers, document setup, test commands, and expected inputs/outputs.
EOF_SOUL
fi

touch "$AI_HERMES_HOME/.env"
chmod 600 "$AI_HERMES_HOME/.env" || true

if [[ "$QUIET" != "--quiet" ]]; then
  echo "Wrote OpenCode config: $AI_OPENCODE_HOME/opencode.json"
  echo "Wrote Hermes config:   $AI_HERMES_HOME/config.yaml"
fi
