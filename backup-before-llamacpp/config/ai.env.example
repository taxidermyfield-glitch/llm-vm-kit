# Main config for the whole local AI VM stack.
# Change AI_HF_MODEL to switch the model used by ai-chat, ai-code, and ai-agent.
#
# Requirement: this must be an Ollama-compatible Hugging Face GGUF reference.
# Valid patterns:
#   hf.co/{owner}/{repo}
#   hf.co/{owner}/{repo}:{quantization}
#   hf.co/{owner}/{repo}:{exact-file-name.gguf}
#
# Example:
#   hf.co/bartowski/Qwen2.5-Coder-7B-Instruct-GGUF:Q4_K_M

AI_HF_MODEL="hf.co/bartowski/Qwen2.5-Coder-7B-Instruct-GGUF:Q4_K_M"

# Stable local Ollama alias. All tools use this alias instead of the long HF path.
AI_MODEL="local-ai"

# Long context is important for coding and agent workflows.
# Lower this if the VM runs out of VRAM.
AI_CONTEXT_LENGTH="64000"

# Persistent runtime locations.
AI_HOME="/workspace/ai"
AI_PROJECTS="/workspace/projects"
OLLAMA_MODELS="/workspace/ai/ollama/models"
AI_HERMES_HOME="/workspace/ai/hermes"
AI_OPENCODE_HOME="/workspace/ai/opencode"

# Keep Ollama private to the VM unless you explicitly expose it.
OLLAMA_HOST="127.0.0.1:11434"

# Hermes autonomous agent defaults.
AI_AGENT_TOOLSETS="hermes-cli"
AI_TERMINAL_TIMEOUT="180"
AI_APPROVAL_MODE="manual"

# Optional local browser CDP endpoint.
# Start it with ai-browser-start, then set:
# AI_BROWSER_CDP_URL="http://127.0.0.1:9222"
AI_BROWSER_CDP_URL=""

# Start local headless Chrome automatically when ai-agent launches.
AI_AUTO_BROWSER="1"

# Optional Hermes web backend hints.
AI_WEB_SEARCH_BACKEND="ddgs"
AI_WEB_EXTRACT_BACKEND=""
