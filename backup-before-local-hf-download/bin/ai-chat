#!/usr/bin/env bash
set -Eeuo pipefail

AI_STACK_DIR="${AI_STACK_DIR:-$(cat /etc/ai-stack/stack-dir 2>/dev/null || echo /opt/llm-vm-kit)}"
# shellcheck disable=SC1091
source "$AI_STACK_DIR/lib/env.sh"

ai-llama-start >/dev/null

python3 - "$AI_MODEL" "$(ai_openai_url)" "$*" <<'PY'
import json
import sys
import urllib.request

model = sys.argv[1]
base_url = sys.argv[2].rstrip("/")
one_shot = sys.argv[3].strip() if len(sys.argv) > 3 else ""

messages = []

def ask(prompt: str) -> str:
    messages.append({"role": "user", "content": prompt})
    data = json.dumps({
        "model": model,
        "messages": messages,
        "temperature": 0.4,
        "max_tokens": 2048
    }).encode()

    req = urllib.request.Request(
        f"{base_url}/chat/completions",
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST"
    )

    with urllib.request.urlopen(req, timeout=900) as r:
        obj = json.loads(r.read().decode())

    reply = obj["choices"][0]["message"]["content"]
    messages.append({"role": "assistant", "content": reply})
    return reply

if one_shot:
    print(ask(one_shot))
    raise SystemExit

print("ai-chat connected to llama.cpp. Type /bye to exit.")
while True:
    try:
        prompt = input("\nyou> ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        break

    if prompt in {"/bye", "/exit", "exit", "quit"}:
        break
    if not prompt:
        continue

    try:
        print("\nai> " + ask(prompt))
    except Exception as e:
        print(f"\nerror: {e}", file=sys.stderr)
PY
