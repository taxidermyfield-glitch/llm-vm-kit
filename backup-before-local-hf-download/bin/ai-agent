#!/usr/bin/env bash
set -Eeuo pipefail

AI_STACK_DIR="${AI_STACK_DIR:-$(cat /etc/ai-stack/stack-dir 2>/dev/null || echo /opt/llm-vm-kit)}"
# shellcheck disable=SC1091
source "$AI_STACK_DIR/lib/env.sh"

ai-llama-start >/dev/null

if [[ "${AI_AUTO_BROWSER:-1}" == "1" ]]; then
  if command -v ai-browser-start >/dev/null 2>&1; then
    ai-browser-start --quiet || echo "Warning: browser automation could not start." >&2
  fi
fi

ai-configure --quiet

export HERMES_HOME="$AI_HERMES_HOME"

if [[ $# -gt 0 ]]; then
  exec hermes chat --toolsets "$AI_AGENT_TOOLSETS" -q "$*"
else
  exec hermes chat --toolsets "$AI_AGENT_TOOLSETS"
fi
