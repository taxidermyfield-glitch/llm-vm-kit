#!/usr/bin/env bash
set -Eeuo pipefail

AI_STACK_DIR="${AI_STACK_DIR:-$(cat /etc/ai-stack/stack-dir 2>/dev/null || echo /opt/llm-vm-kit)}"
# shellcheck disable=SC1091
source "$AI_STACK_DIR/lib/env.sh"

ai-llama-start >/dev/null
ai-configure --quiet

export OPENCODE_CONFIG="$AI_OPENCODE_HOME/opencode.json"
export OPENCODE_CONFIG_DIR="$AI_OPENCODE_HOME"

if [[ $# -gt 0 && -d "$1" ]]; then
  cd "$1"
  shift
fi

if [[ $# -gt 0 ]]; then
  exec opencode run --model "local/${AI_MODEL}" "$@"
else
  exec opencode . --model "local/${AI_MODEL}"
fi
