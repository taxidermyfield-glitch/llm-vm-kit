#!/usr/bin/env bash
set -Eeuo pipefail

AI_STACK_DIR="${AI_STACK_DIR:-$(cat /etc/ai-stack/stack-dir 2>/dev/null || echo /opt/llm-vm-kit)}"
# shellcheck disable=SC1091
source "$AI_STACK_DIR/lib/env.sh"

echo "Config:"
echo "  AI_ENV_FILE:        $AI_ENV_FILE"
echo "  AI_MODEL_PRESET:    $AI_MODEL_PRESET"
echo "  AI_BACKEND:         $AI_BACKEND"
echo "  AI_HF_MODEL:        $AI_HF_MODEL"
echo "  AI_MODEL:           $AI_MODEL"
echo "  AI_CONTEXT_LENGTH:  $AI_CONTEXT_LENGTH"
echo "  AI_OPENAI_BASE_URL: $(ai_openai_url)"
if [[ "${AI_BACKEND:-}" == "vllm" ]]; then
  echo "  AI_VLLM_TP_SIZE:    ${AI_VLLM_TENSOR_PARALLEL_SIZE:-auto}"
fi
echo "  AI_HOME:            $AI_HOME"
echo "  AI_PROJECTS:        $AI_PROJECTS"
echo "  HERMES_HOME:        $AI_HERMES_HOME"
echo "  SYSTEM_PROMPT_FILE: $AI_SYSTEM_PROMPT_FILE"
echo "  AI_SYNC_REMOTE:     ${AI_SYNC_REMOTE_USER:-unset}@${AI_SYNC_REMOTE_HOST:-unset}"
echo "  AI_SYNC_ROOT:       $AI_SYNC_REMOTE_ROOT"
echo "  AI_REQUIRE_SYNC:    $AI_REQUIRE_SYNC_CONFIG"
echo

echo "GPU:"
if command -v nvidia-smi >/dev/null 2>&1; then
  nvidia-smi --query-gpu=name,memory.total,driver_version --format=csv,noheader || true
else
  echo "  nvidia-smi not found"
fi
echo

echo "Tools:"
for cmd in llama-server vllm opencode hermes ai-chat ai-code ai-agent ai-model ai-pull ai-server-start ai-server-stop ai-vllm-start ai-vllm-stop set-system-prompt ai-sync-from-server ai-sync-to-server ai-sync-status ai-llama-start ai-llama-stop; do
  printf "  %-18s " "$cmd"
  command -v "$cmd" || true
done
echo

echo "OpenAI-compatible server:"
if curl -fsS "http://${AI_LLAMA_HOST}:${AI_LLAMA_PORT}/v1/models" >/dev/null 2>&1; then
  echo "  running at $(ai_openai_url)"
  curl -fsS "http://${AI_LLAMA_HOST}:${AI_LLAMA_PORT}/v1/models" | head -c 1000 || true
  echo
else
  echo "  not running"
fi
