#!/usr/bin/env bash
set -Eeuo pipefail

AI_STACK_DIR="${AI_STACK_DIR:-$(cat /etc/ai-stack/stack-dir 2>/dev/null || echo /opt/llm-vm-kit)}"
# shellcheck disable=SC1091
source "$AI_STACK_DIR/lib/env.sh"

mkdir -p "$AI_HOME/logs"

server_url="http://${AI_LLAMA_HOST}:${AI_LLAMA_PORT}"
openai_url="${server_url}/v1"
log_file="$AI_HOME/logs/vllm-server.log"
pid_file="$AI_HOME/logs/vllm-server.pid"

if curl -fsS "${openai_url}/models" >/dev/null 2>&1; then
  echo "vLLM server already running at ${openai_url}"
  exit 0
fi

if ! command -v vllm >/dev/null 2>&1; then
  echo "vLLM not found. Run bootstrap.sh with AI_BACKEND=vllm or install vllm." >&2
  exit 1
fi

model_ref="${AI_HF_MODEL#https://huggingface.co/}"
model_ref="${model_ref#hf.co/}"

tp_args=()
if [[ -n "${AI_VLLM_TENSOR_PARALLEL_SIZE:-}" ]]; then
  tp_args=(--tensor-parallel-size "$AI_VLLM_TENSOR_PARALLEL_SIZE")
fi

extra_args=()
if [[ -n "${AI_VLLM_EXTRA_ARGS:-}" ]]; then
  # shellcheck disable=SC2206
  extra_args=(${AI_VLLM_EXTRA_ARGS})
fi

echo "Starting vLLM server..."
echo "Model: $model_ref"
echo "Context: $AI_CONTEXT_LENGTH"
echo "Endpoint: $openai_url"
echo "Log: $log_file"

pkill -f "vllm.*${AI_LLAMA_PORT}" 2>/dev/null || true
sleep 1

nohup env \
  CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0,1,2,3,4,5,6,7}" \
  vllm serve "$model_ref" \
    --served-model-name "$AI_MODEL" \
    --host "$AI_LLAMA_HOST" \
    --port "$AI_LLAMA_PORT" \
    --dtype "$AI_VLLM_DTYPE" \
    --gpu-memory-utilization "$AI_VLLM_GPU_MEMORY_UTILIZATION" \
    --max-model-len "$AI_CONTEXT_LENGTH" \
    "${tp_args[@]}" \
    "${extra_args[@]}" \
  > "$log_file" 2>&1 &

pid="$!"
echo "$pid" > "$pid_file"

for _ in $(seq 1 600); do
  if curl -fsS "${openai_url}/models" >/dev/null 2>&1; then
    echo "vLLM server ready at $openai_url"
    exit 0
  fi

  if ! kill -0 "$pid" 2>/dev/null; then
    echo "vLLM server exited before becoming ready." >&2
    echo
    echo "Last 200 log lines:" >&2
    tail -200 "$log_file" >&2 || true
    exit 1
  fi

  sleep 2
done

echo "vLLM server did not become ready in time." >&2
echo
echo "Last 200 log lines:" >&2
tail -200 "$log_file" >&2 || true
exit 1
