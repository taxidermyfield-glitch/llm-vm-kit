#!/usr/bin/env bash
set -Eeuo pipefail

AI_STACK_DIR="${AI_STACK_DIR:-$(cat /etc/ai-stack/stack-dir 2>/dev/null || echo /opt/llm-vm-kit)}"
# shellcheck disable=SC1091
source "$AI_STACK_DIR/lib/env.sh"

ENV_FILE="$AI_ENV_FILE"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "No env file found at $ENV_FILE" >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  echo "Config: $ENV_FILE"
  echo
  grep -E '^(AI_HF_MODEL|AI_MODEL|AI_CONTEXT_LENGTH)=' "$ENV_FILE" || true
  echo
  echo "To switch:"
  echo '  ai-model hf.co/bartowski/Llama-3.2-3B-Instruct-GGUF:Q4_K_M'
  exit 0
fi

new_model="$1"

case "$new_model" in
  hf.co/*|huggingface.co/*)
    ;;
  *)
    echo "Expected a Hugging Face GGUF reference usable by Ollama." >&2
    echo "Example: hf.co/bartowski/Qwen2.5-Coder-7B-Instruct-GGUF:Q4_K_M" >&2
    exit 1
    ;;
esac

python3 - "$ENV_FILE" "$new_model" <<'PY'
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
model = sys.argv[2]

lines = path.read_text().splitlines()
out = []
found = False

for line in lines:
    if line.startswith("AI_HF_MODEL="):
        out.append(f'AI_HF_MODEL="{model}"')
        found = True
    else:
        out.append(line)

if not found:
    out.insert(0, f'AI_HF_MODEL="{model}"')

path.write_text("\n".join(out) + "\n")
PY

echo "Set AI_HF_MODEL=$new_model"
ai-pull
