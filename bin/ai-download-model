#!/usr/bin/env bash
set -Eeuo pipefail

AI_STACK_DIR="${AI_STACK_DIR:-$(cat /etc/ai-stack/stack-dir 2>/dev/null || echo /opt/llm-vm-kit)}"
# shellcheck disable=SC1091
source "$AI_STACK_DIR/lib/env.sh"

ENV_FILE="${AI_ENV_FILE:-/workspace/ai/ai.env}"
MODELS_ROOT="${AI_MODELS_DIR:-${AI_HOME:-/workspace/ai}/models}"

if ! command -v hf >/dev/null 2>&1; then
  echo "hf command not found. Run bootstrap or install huggingface_hub[cli]." >&2
  exit 1
fi

if [[ -z "${AI_HF_MODEL:-}" ]]; then
  echo "AI_HF_MODEL is empty." >&2
  exit 1
fi

model_ref="${AI_HF_MODEL#https://huggingface.co/}"
model_ref="${model_ref#hf.co/}"

if [[ "$model_ref" != *:* ]]; then
  echo "AI_HF_MODEL must include a quant/tag after ':'" >&2
  echo "Example: hf.co/owner/repo:UD-IQ2_M" >&2
  exit 1
fi

repo="${model_ref%:*}"
quant="${model_ref##*:}"

# Always derive quant from AI_HF_MODEL so stale Q4_K_M does not break other repos.
AI_MODEL_QUANT="$quant"
export AI_MODEL_QUANT

target_dir="${MODELS_ROOT}/${repo}"

echo "Hugging Face repo: ${repo}"
echo "Requested quant/file: ${quant}"
echo "Download root: ${MODELS_ROOT}"
echo "Target dir: ${target_dir}"

mkdir -p "$target_dir"

echo "Downloading all matching GGUF files for quant/tag '${quant}'..."
hf download "$repo" \
  --include "*${quant}*.gguf" \
  --local-dir "$target_dir"

mapfile -t first_splits < <(
  find "$target_dir" -maxdepth 1 -type f -iname "*.gguf" -iname "*${quant}*" -iname "*00001-of-*.gguf" | sort
)

if [[ "${#first_splits[@]}" -gt 0 ]]; then
  local_model="${first_splits[0]}"
else
  mapfile -t ggufs < <(
    find "$target_dir" -maxdepth 1 -type f -iname "*.gguf" -iname "*${quant}*" | sort
  )

  if [[ "${#ggufs[@]}" -eq 0 ]]; then
    echo "No local GGUF files matching quant/tag '${quant}' found after download." >&2
    echo "Local files:" >&2
    find "$target_dir" -maxdepth 1 -type f -iname "*.gguf" -printf "  %f\n" | sort >&2 || true
    exit 1
  fi

  local_model="${ggufs[0]}"
fi

echo "Selected local model entrypoint:"
echo "  ${local_model}"

echo "Local GGUF files:"
find "$target_dir" -maxdepth 1 -type f -iname "*.gguf" -printf "  %f\n" | sort

python3 - "$ENV_FILE" "$AI_HF_MODEL" "$quant" "$local_model" <<'PY'
from pathlib import Path
import sys

env_path = Path(sys.argv[1])
hf_model = sys.argv[2]
quant = sys.argv[3]
local_model = sys.argv[4]

updates = {
    "AI_HF_MODEL": hf_model,
    "AI_MODEL_QUANT": quant,
    "AI_LOCAL_MODEL": local_model,
}

lines = env_path.read_text().splitlines() if env_path.exists() else []
out = []
seen = set()

for line in lines:
    key = line.split("=", 1)[0] if "=" in line else None
    if key in updates:
        out.append(f'{key}="{updates[key]}"')
        seen.add(key)
    else:
        out.append(line)

for key, value in updates.items():
    if key not in seen:
        out.append(f'{key}="{value}"')

env_path.write_text("\n".join(out) + "\n")
PY

echo "Updated env:"
grep -E 'AI_HF_MODEL|AI_MODEL_QUANT|AI_LOCAL_MODEL|AI_CONTEXT_LENGTH' "$ENV_FILE" || true
