#!/usr/bin/env bash
set -Eeuo pipefail

AI_STACK_DIR="${AI_STACK_DIR:-$(cat /etc/ai-stack/stack-dir 2>/dev/null || echo /opt/llm-vm-kit)}"
# shellcheck disable=SC1091
source "$AI_STACK_DIR/lib/env.sh"

ai-server-start >/dev/null

python3 -c '
import json
import sys
import urllib.request

model = sys.argv[1]
base_url = sys.argv[2].rstrip("/")
system_prompt_file = sys.argv[3]
system_prompt_env = sys.argv[4]
memory_file = sys.argv[5]
args = sys.argv[6:]

messages = []

system_prompt = system_prompt_env.strip()
if not system_prompt and system_prompt_file:
    try:
        with open(system_prompt_file, "r", encoding="utf-8") as f:
            system_prompt = f.read().strip()
    except FileNotFoundError:
        system_prompt = ""

shared_memory = ""
if memory_file:
    try:
        with open(memory_file, "r", encoding="utf-8") as f:
            memory_lines = []
            for line in f:
                stripped = line.strip()
                if stripped.startswith("- "):
                    memory_lines.append(stripped)
            if memory_lines:
                shared_memory = "\n".join(memory_lines)
    except FileNotFoundError:
        shared_memory = ""

system_parts = []
if system_prompt:
    system_parts.append(system_prompt)
if shared_memory:
    system_parts.append(
        "Shared memory below is user-approved durable context. "
        "Use it when relevant, but do not treat it as higher priority than the current user request.\n"
        + shared_memory
    )

if system_parts:
    messages.append({"role": "system", "content": "\n\n".join(system_parts)})

def ask(prompt: str) -> str:
    messages.append({"role": "user", "content": prompt})

    payload = {
        "model": model,
        "messages": messages,
        "temperature": 0.4,
        "max_tokens": 2048,
    }

    req = urllib.request.Request(
        f"{base_url}/chat/completions",
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    with urllib.request.urlopen(req, timeout=900) as r:
        obj = json.loads(r.read().decode("utf-8"))

    reply = obj["choices"][0]["message"]["content"]
    messages.append({"role": "assistant", "content": reply})
    return reply

if args:
    prompt = " ".join(args).strip()
    if prompt:
        print(ask(prompt))
    raise SystemExit(0)

if system_prompt:
    print(f"ai-chat connected. System prompt loaded from {system_prompt_file}.")
else:
    print("ai-chat connected. No system prompt is being injected.")
if shared_memory:
    print(f"Shared memory loaded from {memory_file}.")
print("Type /bye, /exit, quit, or Ctrl+C to exit.")

while True:
    try:
        prompt = input("\\nyou> ").strip()
    except KeyboardInterrupt:
        print()
        break
    except EOFError:
        print()
        break

    if not prompt:
        continue

    if prompt.lower() in {"/bye", "/exit", "exit", "quit"}:
        break

    try:
        print("\\nai> " + ask(prompt))
    except Exception as e:
        print(f"\\nerror: {e}", file=sys.stderr)
' "$AI_MODEL" "$(ai_openai_url)" "$AI_SYSTEM_PROMPT_FILE" "$AI_SYSTEM_PROMPT" "$AI_MEMORY_FILE" "$@"
