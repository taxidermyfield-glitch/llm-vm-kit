# Main config for llm-vm-kit.

AI_MODEL_PRESET="llama-3.3-70b"
AI_BACKEND="llamacpp"

# Hugging Face GGUF model.
# For llama.cpp, this may be either:
#   hf.co/OWNER/REPO:QUANT
# or:
#   OWNER/REPO:QUANT
AI_HF_MODEL="hf.co/bartowski/Llama-3.3-70B-Instruct-abliterated-GGUF:Q4_K_M"

# Model name exposed to OpenAI-compatible clients.
AI_MODEL="local-ai"

# Context length. The 70B default uses a pragmatic 32K context.
# The max-power Hermes 3 405B preset uses 128K context.
AI_CONTEXT_LENGTH="32768"

# Persistent paths.
AI_HOME="/workspace/ai"
AI_PROJECTS="/workspace/projects"
AI_HERMES_HOME="/workspace/ai/hermes"
AI_OPENCODE_HOME="/workspace/ai/opencode"
AI_SYSTEM_PROMPT_FILE="/workspace/ai/persistent-config/system-prompt.txt"
AI_SYSTEM_PROMPT=""
AI_MEMORY_DIR="/workspace/ai/persistent-config/memory"
AI_MEMORY_FILE="/workspace/ai/persistent-config/memory/active.md"

# llama.cpp server settings.
AI_LLAMA_HOST="127.0.0.1"
AI_LLAMA_PORT="18080"
AI_OPENAI_BASE_URL="http://127.0.0.1:18080/v1"
AI_LLAMA_NGL="999"
AI_LLAMA_SPLIT_MODE="layer"
AI_LLAMA_EXTRA_ARGS="--jinja"

# vLLM server settings for non-GGUF presets such as Hermes 3 405B.
AI_VLLM_TENSOR_PARALLEL_SIZE=""
AI_VLLM_DTYPE="auto"
AI_VLLM_GPU_MEMORY_UTILIZATION="0.90"
AI_VLLM_EXTRA_ARGS="--trust-remote-code"

# Install the non-selected built-in backend during bootstrap when possible.
# Keep this enabled if you want easier switching between mid-range and max-power presets.
AI_INSTALL_OPTIONAL_BACKENDS="1"

# Browser automation for Hermes.
AI_AUTO_BROWSER="1"
AI_BROWSER_CDP_URL=""

# Hermes defaults.
AI_AGENT_TOOLSETS="hermes-cli"
AI_TERMINAL_TIMEOUT="180"
AI_APPROVAL_MODE="manual"
AI_WEB_SEARCH_BACKEND="ddgs"
AI_WEB_EXTRACT_BACKEND=""


# Optional local GGUF file path.
# If this points to an existing .gguf file, llama.cpp loads it with -m instead of downloading with -hf.

# Quant/file selector used by ai-download-model.
# Examples: Q4_K_M, Q5_K_M, Q6_K, Q8_0, BF16, or exact-file-name.gguf
AI_MODEL_QUANT="Q4_K_M"
